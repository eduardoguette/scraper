# Token que exige la API en el header Authorization: Bearer <token>.
# Debe coincidir con el secret SCRAPER_TOKEN configurado en Supabase (Later).
# En producción (swarm) se inyecta como Docker secret montado en
# /run/secrets/later_scraper_token; esta env var es el fallback para local.
LATER_SCRAPER_TOKEN=
# Alternativa: ruta a un fichero con el token (Docker secret).
# LATER_SCRAPER_TOKEN_FILE=/run/secrets/later_scraper_token

# Navegadores stealth concurrentes (RAM ~1 GB c/u). Default 2.
SCRAPER_MAX_CONCURRENT=2
